{
  "build": {
    "dockerfile": "./Dockerfile",
    "context": ".."
  },
  "remoteUser": "root",
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/root/.claude,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.config/opencode,target=/root/.config/opencode,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.local/share/opencode,target=/root/.local/share/opencode,type=bind,consistency=cached"
  ],
  "postCreateCommand": "task deps",
  "customizations": {
    "vscode": {
      "extensions": [
        "varavel.vdl",
        "dprint.dprint",
        "svelte.svelte-vscode",
        "Chanzhaoyu.svelte-5-snippets",
        "bradlc.vscode-tailwindcss",
        "biomejs.biome"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "dprint.dprint",
        "editor.codeActionsOnSave": {
          "source.fixAll.biome": "explicit"
        },

        "[vdl]": {
          "editor.defaultFormatter": "varavel.vdl"
        },

        "files.associations": {
          "*.css": "tailwindcss"
        },
        "css.validate": false,

        "[javascript]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[typescript]": {
          "editor.defaultFormatter": "biomejs.biome"
        },

        "svelte.enable-ts-plugin": true,
        "[svelte]": {
          "editor.defaultFormatter": "biomejs.biome"
        }
      }
    }
  }
}
